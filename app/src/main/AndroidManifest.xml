<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="io.shubham0204.smollmandroid">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- Aura AI Automation Permissions -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    
    <!-- Features -->
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="true" />

    <application
        android:name=".SmolChatApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmolChat"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SmolChat"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- App Settings Activity -->
        <activity
            android:name=".AppSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- Chat Settings Activity -->
        <activity
            android:name=".chat_settings.ChatSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- Model List Activity -->
        <activity
            android:name=".models.ModelListActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- Download Model Activity -->
        <activity
            android:name=".models.DownloadModelActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- HF Browse Activity -->
        <activity
            android:name=".models.HFBrowseActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- HF Model Details Activity -->
        <activity
            android:name=".models.HFModelDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- Task Create Activity -->
        <activity
            android:name=".tasks.TaskCreateActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- Task Edit Activity -->
        <activity
            android:name=".tasks.TaskEditActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- Tasks Manage Activity -->
        <activity
            android:name=".tasks.TasksManageActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- File Picker Activity -->
        <activity
            android:name=".models.FilePickerActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- Model Import Activity -->
        <activity
            android:name=".models.ModelImportActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- Model Import Summary Activity -->
        <activity
            android:name=".models.ModelImportSummaryActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- Benchmark Activity -->
        <activity
            android:name=".benchmark.BenchmarkActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- Chat Folder Selection Activity -->
        <activity
            android:name=".chat_settings.ChatFolderSelectionActivity"
            android:exported="false"
            android:theme="@style/Theme.SmolChat" />

        <!-- Speech Recognition Service -->
        <service
            android:name=".services.SpeechRecognitionService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- Download Service -->
        <service
            android:name=".models.DownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Aura AI Accessibility Service -->
        <service
            android:name=".automation.AuraAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- File Provider -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- WorkManager Provider -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge" />

    </application>

</manifest>
